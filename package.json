{
  "name": "tajerp_ui",
  "version": "0.1.0",
  "description": "Tijorat+ design system — shared React component library and design tokens for TajERP front-ends.",
  "license": "MIT",
  "author": "Tijorat+",
  "homepage": "https://www.tijorat.plus",
  "bugs": {
    "url": "https://github.com/TijoratPlus/tajerp_ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TijoratPlus/tajerp_ui.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src",
    "styles",
    "config"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js"
    },
    "./charts": {
      "types": "./dist/charts.d.ts",
      "import": "./dist/charts.js"
    },
    "./form": {
      "types": "./dist/form.d.ts",
      "import": "./dist/form.js"
    },
    "./styles/index.css": "./styles/index.css",
    "./styles/fonts.css": "./styles/fonts.css",
    "./styles/tokens.css": "./styles/tokens.css",
    "./styles/base.css": "./styles/base.css",
    "./styles/frappe-theme.css": "./styles/frappe-theme.css",
    "./styles/compiled.css": "./dist/tajerp-ui.css",
    "./tailwind": "./styles/tokens.css",
    "./eslint": "./config/eslint.config.js",
    "./tsconfig.base.json": "./config/tsconfig.base.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "tailwindcss -i styles/compiled.entry.css -o dist/tajerp-ui.css --minify && node scripts/scope-css.mjs dist/tajerp-ui.css",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist storybook-static",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "comment-deps": "Radix + lucide are real dependencies so installing tajerp_ui pulls them in — consumers should NOT install Radix themselves. Radix uses React context to connect Root/Trigger/Title, so a single physical copy must exist; routing all Radix usage through tajerp_ui guarantees that. Only react/react-dom stay peers (they must be the host app's copy).",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7"
  },
  "peerDependenciesMeta": {
    "react-hook-form": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.14",
    "embla-carousel-react": "^8.6.0",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@tailwindcss/cli": "^4.1.17",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "react-hook-form": "^7.65.0",
    "storybook": "^8.6.0",
    "tailwindcss": "^4.1.17",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^6.0.0"
  }
}
